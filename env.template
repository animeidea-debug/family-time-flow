# ==============================================================================
# Environment Configuration Template
# Copy to env.local, fill in your values, NEVER commit env.local
#
# For shared NAS config across all projects, use ~/.nas-env instead:
#   NAS_IP / SSH_USER / SSH_PORT / SSH_KEY_PATH / SSH_HOST_ALIAS
#   NAS_WEBDAV_PORT / NAS_DATA_ROOT
#   KEYCHAIN_SSH_SERVICE / KEYCHAIN_WEBDAV_SERVICE
#
# Passwords NEVER in files → macOS Keychain:
#   SSH:    security add-generic-password -s "$KEYCHAIN_SSH_SERVICE" -a "$SSH_USER" -w "your-password"
#   WebDAV: security add-generic-password -s "$KEYCHAIN_WEBDAV_SERVICE" -a "$USER" -w "your-password"
# ==============================================================================
PROJECT_NAME="<project-name>"

# --- NAS ---
NAS_USER="<nas-username>"
NAS_IP="<192.168.x.x>"
NAS_WEBDAV_PORT="8888"

# --- External Access ---
DOMAIN_PUBLIC="<tailscale-funnel-or-zconnect-url>"

# --- Ports ---
NGINX_PORT="8888"
BACKEND_PORT="3000"

# --- FamilyTimeFlow backend safety defaults ---
# Keep these disabled until the corresponding review stage is complete.
ENABLE_DIAGNOSTICS="0"
ENABLE_IMMICH="0"
ENABLE_IMMICH_ADMIN="0"
BACKUP_LIMIT="7"

# --- Paths (NAS host) ---
NAS_DATA_ROOT="/tmp/zfsv3/nvme14/<user-id>/data"

# --- Keychain Service Names (project-specific) ---
KEYCHAIN_SSH_SERVICE="nas-ssh"
KEYCHAIN_WEBDAV_SERVICE="my-webdav"

# --- Project Path (for multi-project nginx isolation) ---
# This path is used for URL routing: /<PROJECT_PATH>/
# Must be unique across projects sharing the same nginx server
PROJECT_PATH="family-time-flow"
